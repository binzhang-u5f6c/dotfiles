                                "level": 0,
                                "security": "auto"
                            }
                        ]
                    }
                ]
            },
            "tag": "proxy",
            "streamSettings": {
                "network": "ws",
                "security": "tls",
                "tlsSettings": {
                    "serverName": "",
                    "allowInsecure": false,
                    "alpn": [],
                    "certificates": [],
                    "disableSystemRoot": false
                },
                "tcpSettings": {
                    "header": {
                        "type": "none"
